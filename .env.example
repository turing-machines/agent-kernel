# copy to .env — or just rely on ANTHROPIC_API_KEY already exported in your shell
ANTHROPIC_API_KEY=your-key-here
# the processor (the LLM). sonnet is a good default; swap to claude-opus-4-8 or claude-haiku-4-5-20251001
MODEL=claude-sonnet-4-6
# per-step output (context write) budget
MAX_TOKENS=1024
# max main-frame steps without yielding to the operator (cost guard)
MAX_BURST=16
# per-subroutine step budget (runaway guard)
MAX_STEPS=12
# invoke recursion-depth guard
MAX_DEPTH=5
# durable disk image for M
MEM_FILE=m.json
